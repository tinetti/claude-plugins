{
  "name": "claude-plugins",
  "version": "0.1.1",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "sync": "tsx scripts/sync-marketplace.ts",
    "build": "pnpm -r --if-present run bundle",
    "typecheck": "tsc --build",
    "test": "node --import tsx --test tests/*.test.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "skills": [
      "plugins/*/skills"
    ],
    "prompts": [
      "plugins/*/commands/*.md"
    ],
    "extensions": [
      "pi/extensions/*.ts"
    ]
  }
}
