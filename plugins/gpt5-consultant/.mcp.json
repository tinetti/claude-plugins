{
  "mcpServers": {
    "gpt5-server": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/dist/index.js"],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "codex": {
      "command": "codex",
      "args": [
        "-m",
        "gpt-5-codex",
        "-c",
        "model_reasoning_effort=\"high\"",
        "mcp-server"
      ]
    }
  }
}
