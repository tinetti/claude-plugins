{
  "name": "gpt5-mcp-server",
  "version": "0.3.0",
  "description": "MCP server for OpenAI GPT-5 API integration",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "gpt5-mcp-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:fsevents",
    "start": "node build/index.js",
    "dev": "tsc && node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.3.2"
  }
}
